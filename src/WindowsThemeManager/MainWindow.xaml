<Window x:Class="WindowsThemeManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:converters="clr-namespace:WindowsThemeManager.Converters"
        mc:Ignorable="d"
        Title="Windows Theme Manager"
        Height="700" Width="1200"
        MinHeight="500" MinWidth="800"
        WindowStartupLocation="CenterScreen"
        PreviewMouseDown="Window_PreviewMouseDown"
        Name="RootWindow">

    <Window.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <converters:ActiveThemeBackgroundConverter x:Key="ActiveThemeBackgroundConverter"/>
        <converters:ActiveThemeBorderConverter x:Key="ActiveThemeBorderConverter"/>
        <converters:BoolToIconConverter x:Key="BoolToIconConverter"/>
        <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
        <converters:DoubleToGridLengthConverter x:Key="DoubleToGridLengthConverter"/>

        <DataTemplate x:Key="ThemeItemTemplate">
            <Border Padding="8,4"
                    Background="{Binding IsActive, Converter={StaticResource ActiveThemeBackgroundConverter}}"
                    BorderBrush="{Binding IsActive, Converter={StaticResource ActiveThemeBorderConverter}}"
                    BorderThickness="2"
                    CornerRadius="4"
                    Margin="2">
                <StackPanel Orientation="Horizontal" Cursor="Hand">
                    <TextBlock Text="{Binding IsSystemTheme, Converter={StaticResource BoolToIconConverter}, FallbackValue=&#x1F3A8;}"
                               FontSize="16"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0"/>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="{Binding Theme.DisplayName}"
                                   FontWeight="SemiBold"
                                   FontSize="13"
                                   Name="ThemeItemNameText"/>
                        <TextBlock Text="{Binding Theme.ThemePath}"
                                   FontSize="10"
                                   Name="ThemeItemPathText"
                                   TextTrimming="CharacterEllipsis"
                                   MaxWidth="250"/>
                    </StackPanel>
                    <TextBlock Text="..."
                               FontSize="14"
                               VerticalAlignment="Center"
                               Margin="8,0,0,0"
                               Visibility="{Binding IsApplying, Converter={StaticResource BoolToVisibilityConverter}}"/>
                </StackPanel>
                <Border.InputBindings>
                    <MouseBinding MouseAction="LeftClick"
                                  Command="{Binding ApplyCommand}"/>
                </Border.InputBindings>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="MonitorItemTemplate">
            <Button Command="{Binding OpenWallpaperCommand}"
                    Cursor="Hand"
                    ToolTip="{Binding TooltipText}"
                    BorderBrush="#555"
                    BorderThickness="2"
                    Background="#2A2A2A"
                    Padding="0"
                    Name="MonitorItemButton">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            Background="{TemplateBinding Background}">
                                        <ContentPresenter/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="BorderBrush" Value="#0078D4"/>
                                <Setter Property="BorderThickness" Value="3"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
                <Grid>
                    <Image Source="{Binding WallpaperPreview}"
                           Stretch="Uniform"
                           Opacity="0.8"/>
                    <Rectangle Fill="#3A3A3A"
                               Visibility="{Binding WallpaperPreview, Converter={StaticResource NullToVisibilityConverter}}"/>
                    <TextBlock Text="No Wallpaper"
                               FontSize="12"
                               Foreground="#888888"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Visibility="{Binding WallpaperPreview, Converter={StaticResource NullToVisibilityConverter}}"/>
                    <Border Background="#AA000000"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            CornerRadius="20"
                            MinWidth="40"
                            MinHeight="40"
                            Margin="8,8,0,0">
                        <TextBlock Text="{Binding MonitorNumber}"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Foreground="#FFFFFF"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="{Binding DeviceName}"
                               Background="#AA000000"
                               Foreground="#FFFFFF"
                               FontSize="10"
                               TextAlignment="Center"
                               VerticalAlignment="Bottom"
                               Margin="2"/>
                </Grid>
            </Button>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="{Binding ThemePanelWidth, Mode=TwoWay, Converter={StaticResource DoubleToGridLengthConverter}}"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <DockPanel Grid.Column="0" Grid.Row="0" Name="ThemePanelDock" Background="#F5F5F5">
            <Border DockPanel.Dock="Top" Name="ThemePanelHeaderBorder" Background="#E8E8E8">
                <StackPanel Margin="12,8">
                    <TextBlock Name="ThemePanelHeaderText" Text="Available Themes"
                               FontSize="16" FontWeight="SemiBold" Foreground="#000000" Margin="0,0,0,4"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Stretch">
                        <Button Content="Refresh" Command="{Binding RefreshCommand}" Padding="8,4" FontSize="11"/>
                        <TextBlock Text="{Binding StatusMessage}"
                                   FontSize="10" Foreground="#808080" VerticalAlignment="Center"
                                   Margin="8,0,0,0" TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Name="LoadingBorder" Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}"
                    Background="#80FFFFFF" Panel.ZIndex="1">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="⏳" FontSize="32" HorizontalAlignment="Center" Margin="0,0,0,12" Foreground="#000000">
                        <TextBlock.RenderTransform>
                            <RotateTransform CenterX="16" CenterY="16"/>
                        </TextBlock.RenderTransform>
                    </TextBlock>
                    <TextBlock Text="Loading themes..." FontSize="14" HorizontalAlignment="Center" Foreground="#333333"/>
                </StackPanel>
            </Border>

            <ListBox ItemsSource="{Binding Themes}"
                     ItemTemplate="{StaticResource ThemeItemTemplate}"
                     SelectedItem="{Binding SelectedTheme}"
                     Background="Transparent" BorderThickness="0"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"/>
        </DockPanel>

        <GridSplitter Grid.Column="1" Grid.Row="0" Width="4" HorizontalAlignment="Center"
                      VerticalAlignment="Stretch" Cursor="SizeWE"
                      Name="MainGridSplitter" Background="#CCCCCC"/>

        <Grid Grid.Column="2" Grid.Row="0" Name="MonitorAreaGrid" Background="#1E1E1E">
            <TextBlock Name="MonitorAreaHeaderText" Text="Monitor Layout"
                       FontSize="14" FontWeight="SemiBold" Foreground="#FFFFFF"
                       Margin="16,12,0,0" Panel.ZIndex="1"/>

            <Border Name="MonitorLoadingBorder" Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}"
                    Background="#801E1E1E" Panel.ZIndex="2">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="⏳" FontSize="32" Foreground="#FFFFFF"
                               HorizontalAlignment="Center" Margin="0,0,0,12"/>
                    <TextBlock Text="Detecting monitors..." FontSize="14" Foreground="#FFFFFF"
                               VerticalAlignment="Center" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" Padding="20">
                <Viewbox Stretch="Uniform" StretchDirection="Both">
                    <ItemsControl ItemsSource="{Binding Monitors}"
                                  ItemTemplate="{StaticResource MonitorItemTemplate}"
                                  Name="MonitorsItemsControl" Width="800" Height="600">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <Canvas Background="Transparent" Width="800" Height="600"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemContainerStyle>
                            <Style>
                                <Setter Property="Canvas.Left" Value="{Binding CanvasLeft}"/>
                                <Setter Property="Canvas.Top" Value="{Binding CanvasTop}"/>
                                <Setter Property="Canvas.Width" Value="{Binding CanvasWidth}"/>
                                <Setter Property="Canvas.Height" Value="{Binding CanvasHeight}"/>
                            </Style>
                        </ItemsControl.ItemContainerStyle>
                    </ItemsControl>
                </Viewbox>
            </ScrollViewer>
        </Grid>

        <!-- Status bar with theme selector -->
        <Border Grid.Column="0" Grid.ColumnSpan="3" Grid.Row="1"
                Name="StatusBarBorder" Background="#E8E8E8"
                BorderBrush="#CCCCCC" BorderThickness="0,1,0,0" Padding="12,4">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <TextBlock Text="Theme:" FontSize="11" Foreground="#808080"
                           VerticalAlignment="Center" Margin="0,0,6,0"/>
                <ComboBox x:Name="ThemeModeComboBox" SelectedIndex="0"
                          SelectionChanged="ThemeModeComboBox_SelectionChanged"
                          Width="80" FontSize="11" VerticalAlignment="Center">
                    <ComboBoxItem Content="System"/>
                    <ComboBoxItem Content="Light"/>
                    <ComboBoxItem Content="Dark"/>
                </ComboBox>
            </StackPanel>
        </Border>
    </Grid>
</Window>
